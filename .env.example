# Railway udfylder selv DATABASE_URL når du tilføjer PostgreSQL-pluginet.
# Lokalt kan du lade den være tom — så bruger appen en lokal pool_state.json.
DATABASE_URL=

# Din Claude API-nøgle fra console.anthropic.com (kun server-side, aldrig i browseren).
ANTHROPIC_API_KEY=

# Valgfrit — default er claude-sonnet-4-6.
CLAUDE_MODEL=claude-sonnet-4-6
